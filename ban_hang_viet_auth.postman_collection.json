{
	"info": {
		"_postman_id": "7a35cbdf-047b-45cf-8472-ee1d88a10987",
		"name": "Bán Hàng Việt - Xác thực & Đăng nhập",
		"description": "Bộ Collection kiểm thử API Đăng ký và Đăng nhập cho dự án Bán Hàng Việt (Spring Boot + Security + JWT).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Đăng ký hộ kinh doanh mới",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Đăng ký thành công\", function () {",
							"    pm.response.to.have.status(200);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.code).to.eql(1000);",
							"    pm.expect(jsonData.result.username).to.eql(pm.variables.get(\"test_username\"));",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Sinh mã số thuế và username ngẫu nhiên để tránh lỗi trùng lặp khi chạy lại nhiều lần",
							"var randomNum = Math.floor(Math.random() * 900000) + 100000;",
							"pm.collectionVariables.set(\"test_taxcode\", \"MST-\" + randomNum);",
							"pm.collectionVariables.set(\"test_username\", \"user_test_\" + randomNum);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"householdName\": \"Hộ kinh doanh Tạp Hóa Postman\",\n    \"taxCode\": \"{{test_taxcode}}\",\n    \"householdAddress\": \"123 Đường Giải Phóng, Hà Nội\",\n    \"householdPhone\": \"0981234567\",\n    \"username\": \"{{test_username}}\",\n    \"password\": \"password123\",\n    \"fullName\": \"Nguyễn Văn Postman\",\n    \"phone\": \"0981234567\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/v1/auth/register",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"auth",
						"register"
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Đăng nhập thành công (Lấy Token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Đăng nhập thành công\", function () {",
							"    pm.response.to.have.status(200);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.code).to.eql(1000);",
							"    pm.expect(jsonData.result.token).to.exist;",
							"    ",
							"    // Lưu token vào biến để các request khác có thể dùng tự động",
							"    pm.collectionVariables.set(\"jwt_token\", jsonData.result.token);",
							"    console.log(\"Đã lưu JWT Token mới:\", jsonData.result.token);",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"{{test_username}}\",\n    \"password\": \"password123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/v1/auth/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Đăng nhập sai mật khẩu (Lỗi 400)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Báo lỗi sai mật khẩu\", function () {",
							"    pm.response.to.have.status(400);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.code).to.eql(2007);",
							"    pm.expect(jsonData.message).to.include(\"Mật khẩu không chính xác\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"{{test_username}}\",\n    \"password\": \"wrongpassword\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/v1/auth/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "4. Đăng nhập tài khoản không tồn tại (Lỗi 404)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Báo lỗi tài khoản không tồn tại\", function () {",
							"    pm.response.to.have.status(404);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.code).to.eql(2001);",
							"    pm.expect(jsonData.message).to.include(\"Người dùng không tồn tại\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"non_existent_username\",\n    \"password\": \"password123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/v1/auth/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "5. Ví dụ gọi API được bảo mật (Dùng Token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Trả về lỗi nếu không truyền token hoặc token hết hạn\", function () {",
							"    // Tùy thuộc vào việc người dùng có truyền token hay không",
							"    if (!pm.collectionVariables.get(\"jwt_token\")) {",
							"        pm.response.to.have.status(403);",
							"    }",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{jwt_token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/v1/users/me (Ví dụ)",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"users",
						"me (Ví dụ)"
					]
				},
				"description": "Để chạy thử request này, hãy chắc chắn đã chạy thành công Request số 2 để lấy token và tự động gán vào biến {{jwt_token}}."
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					""
				],
				"type": "text/javascript"
			}
		},
		{
			"listen": "test",
			"script": {
				"exec": [
					""
				],
				"type": "text/javascript"
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "test_username",
			"value": "",
			"type": "string"
		},
		{
			"key": "test_taxcode",
			"value": "",
			"type": "string"
		}
	]
}
