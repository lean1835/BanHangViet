# ==============================================================
#  BanHangViet — Frontend Environment Variables (Template)
#  Sao chép file này thành .env.local và điền giá trị thực tế.
#  KHÔNG commit file .env.local vào Git.
# ==============================================================

# --- API ---
# URL gốc của Backend API (Spring Boot)
VITE_API_URL=http://localhost:8080/api/v1

# --- App ---
# Môi trường chạy ứng dụng: development | production
VITE_APP_ENV=development
