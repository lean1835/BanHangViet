# ==============================================================
#  BanHangViet — Backend Environment Variables (Template)
#  Sao chép file này thành .env và điền giá trị thực tế.
#  KHÔNG commit file .env vào Git nếu chứa secret thực tế.
# ==============================================================

# --- Database (MySQL) ---
DB_URL=jdbc:mysql://localhost:3306/ban_hang_viet?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USER=root
DB_PASSWORD=your_mysql_password

# --- JWT ---
# Secret key dùng để ký và xác minh JWT token (tối thiểu 256-bit / 64 ký tự hex)
JWT_SECRET=your_jwt_secret_key_minimum_256_bits

# Thời gian hết hạn token tính bằng millisecond (86400000 = 24 giờ)
JWT_EXPIRATION_MS=86400000
